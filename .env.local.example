# Gemini API キー (https://aistudio.google.com/apikey で取得)
# 設定すると連携インボックスのAI解析が Gemini で動作します。
# 未設定の場合はルールベースの簡易解析にフォールバックします。
GEMINI_API_KEY=

# --- Google認証 (必須) ---
# Google Cloud Console > APIとサービス > 認証情報 で作成した
# OAuth 2.0 クライアントID (ウェブアプリケーション) の値を設定してください。
# スコープに .../auth/calendar.readonly を含めた同意画面の設定が必要です。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth のセッション暗号化キー。`openssl rand -base64 32` などで生成してください。
NEXTAUTH_SECRET=
# ローカル開発時は http://localhost:3400、本番は Cloud Run の URL を設定してください。
NEXTAUTH_URL=http://localhost:3400

# --- Firestore ---
# Cloud Run では未設定でも自動検出されます。ローカル開発では
# `gcloud auth application-default login` でADC認証したうえでこのプロジェクトIDを指定してください。
GOOGLE_CLOUD_PROJECT=taskpilot-app-72533
